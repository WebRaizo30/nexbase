# =============================================================================
# Core (required for the API: database, auth, server)
# =============================================================================

# PostgreSQL connection string
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"
#
# Vercel / serverless + Supabase: prefer the "Transaction pooler" connection string
# (host often ends with .pooler.supabase.com, port 6543) and add:
#   ?pgbouncer=true&connection_limit=1
# Direct db.*.supabase.co:5432 can hang or time out from some serverless runtimes.

# JWT — use a long random string in production
JWT_SECRET="replace-with-long-random-string"
JWT_EXPIRES_IN="7d"

# HTTP API
PORT=4000
# Browser origins allowed to call the API (comma-separated in production).
# Example production: https://your-app.vercel.app,https://www.yourdomain.com
CORS_ORIGIN="http://localhost:3000"

# Public URLs (used by frontend and for Stripe return URLs)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
API_URL="http://localhost:4000"
# Backend uses this for Stripe Checkout / Billing Portal success & return URLs
FRONTEND_URL="http://localhost:3000"

# Brand string used in transactional emails (optional)
APP_PUBLIC_NAME="NexBase"

# Comma-separated emails that receive role "admin" on registration (optional)
ADMIN_EMAILS=test@nexbase.test
# Seed script: create or promote admin (optional). Run: npx prisma db seed
ADMIN_SEED_EMAIL=test@nexbase.test
ADMIN_SEED_PASSWORD=test123!

# =============================================================================
# Optional — Stripe Billing (subscriptions, checkout, portal, webhooks)
# =============================================================================
# You do NOT need a Stripe account to run auth, /health, or most of the API.
# If these variables are empty, POST /api/billing/create-checkout and
# POST /api/billing/portal respond with HTTP 503 and a JSON body containing
# "setupSteps" (what to do when you want billing).
#
# When you are ready:
#   1) Create a free Stripe account (test mode is fine).
#   2) Create recurring Prices in Dashboard → Products.
#   3) Fill STRIPE_SECRET_KEY and STRIPE_PRICE_* below.
#   4) For webhooks locally: Stripe CLI → stripe listen --forward-to localhost:4000/api/billing/webhook
#      then set STRIPE_WEBHOOK_SECRET to the whsec_ value.
# =============================================================================

STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
# Publishable key is for the browser (Next.js); backend does not require it.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_PRICE_STARTER=""
STRIPE_PRICE_PRO=""
STRIPE_PRICE_ENTERPRISE=""

# =============================================================================
# Optional — Amazon S3 (file upload / list / delete)
# =============================================================================
# Leave blank until you want uploads. POST /api/files/upload, GET /api/files,
# and DELETE /api/files/:id then return HTTP 503 with JSON "setupSteps".
#
# When you are ready:
#   1) Create a bucket and IAM credentials with PutObject, GetObject, DeleteObject.
#   2) Fill the four variables below and restart the API.
# =============================================================================

AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="eu-central-1"
AWS_S3_BUCKET=""

# =============================================================================
# Optional — transactional email (Resend)
# =============================================================================
# Welcome email sends in the background after register. If RESEND_API_KEY is empty,
# registration still succeeds; no email is sent.
#
# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL="NexBase <onboarding@resend.dev>"
# =============================================================================

RESEND_API_KEY=""
RESEND_FROM_EMAIL=""
