# Browser-exposed (safe) — API base URL for the Express backend
# Production: https://api.yourdomain.com (no trailing slash)
NEXT_PUBLIC_API_URL="http://localhost:4000"

# Optional — Stripe publishable key for future Checkout Elements / client-only flows
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# Optional — matches backend FRONTEND_URL / marketing site origin
NEXT_PUBLIC_APP_URL="http://localhost:3000"
